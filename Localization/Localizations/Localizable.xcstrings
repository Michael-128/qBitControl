    "Inspect, search, and export diagnostic logs securely. Sensitive credentials and passwords are automatically redacted." : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "診断ログを安全に検査、検索、エクスポートできます。機密性の高い資格情報やパスワードは自動的にマスキングされます。"
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bezpiecznie przeglądaj, przeszukuj i eksportuj logi diagnostyczne. Wrażliwe dane logowania i hasła są automatycznie ukrywane."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "安全地检查、搜索和导出诊断日志。敏感的身份凭证与密码将被自动脱敏。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "安全地檢查、搜尋和匯出診斷記錄。敏感的憑證與密碼將會自動遮蔽。"
          }
        }
      }
    },
